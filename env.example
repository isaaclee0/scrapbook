# Database Configuration (use the same value for DB_PASSWORD and MYSQL_PASSWORD in .env;
# docker-compose maps MYSQL_PASSWORD to the app's DB_PASSWORD.)
DB_PASSWORD=your_secure_password_here
MYSQL_PASSWORD=your_secure_password_here
MYSQL_ROOT_PASSWORD=your_secure_root_password_here

# Auth (set in production; compose defaults work for local Docker only)
# JWT_SECRET_KEY=

# Debug Mode (optional)
# Set to 'development' to enable debugging and URL health checking
# Set to 'production' (or leave unset) for production mode
DEBUG_MODE=production

# In development (FLASK_ENV=development or DEBUG_MODE=development), all auth
# emails (OTP / welcome) are delivered to this address regardless of the login
# email typed in the UI. OTP verification still uses the typed address.
# DEV_EMAIL_REDIRECT=isaac@leemail.com.au

# Other Environment Variables (usually don't need to change)
# FLASK_ENV=production
# FLASK_APP=app.py
# PYTHONUNBUFFERED=1
# DB_HOST=db
# DB_USER=db
# DB_NAME=db
# REDIS_HOST=redis
# REDIS_PORT=6379 