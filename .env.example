# Database Configuration
DB_HOST=db
DB_USER=db
DB_PASSWORD=your_secure_password_here
DB_NAME=db

# MySQL Configuration
MYSQL_DATABASE=db
MYSQL_USER=db
MYSQL_PASSWORD=your_secure_password_here
MYSQL_ROOT_PASSWORD=your_secure_root_password_here

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Image cache worker (cache-worker service)
CACHE_WORKER_BATCH_SIZE=200
CACHE_WORKER_SLEEP=10
CACHE_WORKER_THREADS=6
CACHE_WORKER_MAX_IDLE_ROUNDS=0
CACHE_WORKER_IDLE_BACKOFF=300

# Flask Configuration
FLASK_ENV=development
FLASK_APP=app.py
PYTHONUNBUFFERED=1
